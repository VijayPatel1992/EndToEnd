{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "playwright"],
    "resolveJsonModule": true
  },
  "include": [
    "playwright.config.ts",
    "tests/**/*.ts",
    "utility/**/*.ts",
    "pages/**/*.ts",
    "fixtures/**/*.ts",
    "configuration/**/*.ts",
    "constant/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
